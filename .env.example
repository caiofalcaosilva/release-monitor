# ==============================
# Repositories to monitor
# Format: owner/repository
# Multiple repos separated by comma
# Example: owner/repo1,owner/repo2
# At least one of REPOS or GITLAB_REPOS must be set
# ==============================
REPOS=caiofalcaosilva/release-monitor,openai/openai-python

# GitLab repositories (optional)
# GITLAB_REPOS=gitlab-org/gitlab


# ==============================
# Scheduler configuration
# ==============================

# Interval between checks (minutes)
INTERVAL_MINUTES=1

# Ignore pre-releases
# true  = notify only stable releases
# false = notify all releases
IGNORE_PRERELEASE=true


# ==============================
# Notification configuration
# ==============================

# Google Chat webhook URL
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX


# ==============================
# GitHub configuration
# ==============================

# Personal Access Token (optional, but recommended)
# Without it: 60 requests/hour per IP (unauthenticated)
# With it:  5000 requests/hour
# Required scopes: none (public repos only) or repo (private repos)
# GITHUB_TOKEN=ghp_XXXX


# ==============================
# GitLab configuration
# ==============================

# Personal Access Token for GitLab (required for private repos)
# GITLAB_TOKEN=glpat_XXXX

# GitLab instance URL (default: https://gitlab.com)
# Change only for self-hosted GitLab
# GITLAB_URL=https://gitlab.example.com


# ==============================
# Application settings
# ==============================

# File used to store last processed releases
STATE_FILE=/app/data/state.json

# Timezone used to display release time
# Example: UTC, America/New_York, America/Sao_Paulo
TIMEZONE=America/Sao_Paulo